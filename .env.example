# Flask / App
FLASK_ENV=development
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-replace-me

# Database (Postgres)
DATABASE_URL=postgresql://username:password@localhost:5432/injaaz

# Redis (Upstash or local)
REDIS_URL=redis://localhost:6379

# Cloudinary (for client direct uploads and server uploads)
# Sign up at https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_UPLOAD_PRESET=your-upload-preset

# App base URL (used to construct absolute file links, emails, PWA — use public HTTPS URL on Render)
APP_BASE_URL=http://localhost:5000
# Production (Render): FLASK_ENV=production, DATABASE_URL=postgresql://..., set APP_BASE_URL=https://your-service.onrender.com
# SESSION_COOKIE_SECURE=true when served only over HTTPS

# JWT config
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-jwt-secret-key-here-replace-me

# JWT Token Expiry Settings (optional - defaults shown)
# JWT_ACCESS_HOURS: Number of hours access tokens are valid (default: 1)
# JWT_REFRESH_DAYS: Number of days refresh tokens are valid (default: 7)
# JWT_ACCESS_HOURS=1
# JWT_REFRESH_DAYS=7

# Rate Limiting (requests per hour)
RATELIMIT_STORAGE_URL=redis://localhost:6379
RATELIMIT_DEFAULT=100 per hour

# ── Email / SMTP ─────────────────────────────────────────────
# Required for Report Generation and password-reset emails.
# Pick ONE option below and uncomment / fill in .env (see docs/EMAIL_SMTP_OPTIONS.md).
#
# --- Render free tier: use Brevo HTTPS API (SMTP ports blocked) ---
# BREVO_API_KEY=xkeysib-...
# MAIL_DEFAULT_SENDER=noreply@injaaz.ae
#
# --- Option A: Brevo (free 300 emails/day, no credit card) ---
# Sign up: https://www.brevo.com → SMTP & API → SMTP key
# MAIL_SERVER=smtp-relay.brevo.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=your-login-email@injaaz.ae
# MAIL_PASSWORD=your-brevo-smtp-key
# MAIL_DEFAULT_SENDER=noreply@injaaz.ae
#
# --- Option B: SendGrid (free 100/day for 60 days, then paid) ---
# Sign up: https://sendgrid.com → Settings → API Keys → Create (Mail Send)
# MAIL_SERVER=smtp.sendgrid.net
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=apikey
# MAIL_PASSWORD=your-sendgrid-api-key
# MAIL_DEFAULT_SENDER=noreply@injaaz.ae
#
# --- Option C: Mailjet (free tier available) ---
# Sign up: https://www.mailjet.com → Account → SMTP & API (API Key = user, Secret = password)
# MAIL_SERVER=in-v3.mailjet.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=your-mailjet-api-key
# MAIL_PASSWORD=your-mailjet-secret-key
# MAIL_DEFAULT_SENDER=noreply@injaaz.ae
#
# --- Option D: Personal Gmail (your @gmail.com account) ---
# 1) Turn on 2-Step Verification: myaccount.google.com → Security
# 2) App password: myaccount.google.com/apppasswords → create for "Mail"
# Use your full Gmail address and the 16-character app password (no spaces).
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=yourname@gmail.com
# MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
# MAIL_DEFAULT_SENDER=yourname@gmail.com
#
# --- Option E: Google Workspace (injaaz.ae on Google) ---
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=noreply@injaaz.ae
# MAIL_PASSWORD=app-password-from-google-account
# MAIL_DEFAULT_SENDER=noreply@injaaz.ae
#
# --- Option F: Microsoft 365 (if you have Office 365) ---
# MAIL_SERVER=smtp.office365.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=noreply@injaaz.ae
# MAIL_PASSWORD=app-password
# MAIL_DEFAULT_SENDER=noreply@injaaz.ae
